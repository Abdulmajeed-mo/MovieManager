  {
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "AllowedHosts": "*",



    //API from TMDB
    "ApiSettings": {
      "BaseUrl": "https://api.themoviedb.org",
      "ApiKey": "12168762e46dd0866376e9de017572bd"
    },

    //"يخبرالمشروع باستخدام لوكل داتا بيس             يستخدم حساب ويندوز الحالي، لذلك لاتحتاج أو كلمة مرور،     اسم قاعدة البيانات التي ستُنشأ.     يخبر المشروع باستخدام لوكل داتا بيس
    "ConnectionStrings": {
      "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=MovieManagerDB;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=False;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30"
    },
    //Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=MoviesDatabase;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=False;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30

    "Serilog": {
      //يخبر السيريلوق أي السينك سيستخدم.
      "Using": [ "Serilog.Sinks.File" ],

      //أقل مستوى سيتم تسجيله.
      "MinimumLevel": "Information",
      //أين سيتم حفظ الـ Logs.
      "WriteTo": [
        //    استخدم File Sink.
          {"Name": "File",
            "Args": {
              //مكان إنشاء ملفات الـ Logs.
              "path": "Logs/log-.log",
              //كل يوم ينشئ ملفًا جديدًا.
              "rollingInterval": "Day",
              "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
            }
        }
      ]

    }
  }